# Provider API keys — set only the ones you use.
# Loaded from .env.local first, then .env (never committed).
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
XAI_API_KEY=
MINIMAX_API_KEY=
GLM_API_KEY=
DASHSCOPE_API_KEY=
OPENROUTER_API_KEY=

# Maintainers only: path to a checkout of bridgebench-private (hidden probes).
# Public runs work without it — interaction scores are flagged partial.
BRIDGEBENCH_PRIVATE_DIR=

# Optional: explicit Chromium binary for evaluation.
# Official runs use docker/Dockerfile.eval; local runs auto-detect system Chrome.
PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=
