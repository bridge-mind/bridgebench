# The only credential the arena needs. All model traffic goes through
# OpenRouter; set an account-level spending limit before paid runs.
OPENROUTER_API_KEY=

# Maintainers only: a checkout holding the hidden task references, mirroring
# this repo's layout ($BRIDGEBENCH_PRIVATE_DIR/tasks/<category>/private/).
# Without it: tasks validate, report, triage, and the dashboard's read views
# all work; judged arena runs do not (see docs/private-packs.md).
BRIDGEBENCH_PRIVATE_DIR=

# Maintainers only: publishing has no implicit destination. Set the exact API
# base URL and its admin key before running tasks publish or arena publish.
BRIDGEBENCH_API_URL=
BRIDGEBENCH_ADMIN_KEY=
