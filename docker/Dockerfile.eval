# Pinned evaluation image for OFFICIAL BridgeBench runs.
#
# Why: scores must be reproducible. Chromium version, SwiftShader build, and
# system fonts all change rendered pixels — so official runs happen inside
# this image, never on a laptop. Local/dev runs may use system Chrome; their
# numbers are indicative, not official.
#
# Playwright's base image pins both Chromium and the matching playwright-core
# version; fonts-noto keeps text rendering (Kinetic Typography) identical.

FROM mcr.microsoft.com/playwright:v1.58.2-noble

RUN apt-get update \
  && apt-get install -y --no-install-recommends fonts-noto-core fonts-noto-color-emoji \
  && rm -rf /var/lib/apt/lists/*

ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/ms-playwright/chromium-*/chrome-linux/chrome
# Resolve the glob at build time so the env var is a concrete path.
RUN CHROME_PATH=$(ls -d /ms-playwright/chromium-*/chrome-linux/chrome | head -1) \
  && echo "export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=$CHROME_PATH" >> /etc/profile.d/bridgebench.sh \
  && ln -s "$CHROME_PATH" /usr/local/bin/bridgebench-chromium
ENV PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH=/usr/local/bin/bridgebench-chromium

WORKDIR /bench
CMD ["bash"]
